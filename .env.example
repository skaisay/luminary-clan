# Environment Variables for Luminary Clan
# Copy this file to .env and fill in the values

# Database (Neon PostgreSQL)
DATABASE_URL=your-neon-database-url-here

# Session secret (random string)
SESSION_SECRET=change-me-to-a-random-string

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Callback URL for Discord OAuth (set after deploying)
# Example: https://your-app.onrender.com/auth/discord/callback
CALLBACK_URL=http://localhost:5000/auth/discord/callback

# Port (Render sets this automatically)
PORT=5000
